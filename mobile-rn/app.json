{
  "expo": {
    "name": "Abcotronics ERP",
    "slug": "abcotronics-erp-mobile",
    "version": "0.4.2",
    "orientation": "portrait",
    "scheme": "abcotronics",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.abcotronics.erp.mobile",
      "versionCode": 17,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1d4ed8"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow location access when you pick a visit point on the map or track travel distance.",
          "isAndroidBackgroundLocationEnabled": false,
          "isIosBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow camera access for job card photos and stock-take barcode scanning."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow photo library access for job card attachments and expense receipts.",
          "cameraPermission": "Allow camera access to photograph expense receipts."
        }
      ],
      "expo-document-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1d4ed8",
          "sounds": [
            "./assets/sounds/message.wav",
            "./assets/sounds/notification.wav"
          ]
        }
      ],
      "expo-updates"
    ]
  }
}
