EXPO_PUBLIC_API_BASE_URL=https://abcoafrica.co.za
EXPO_PUBLIC_APP_ENV=pilot
# Optional: Sentry crash reporting (requires native rebuild after setting)
# EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Optional: Expo access token for non-interactive EAS/OTA (https://expo.dev/settings/access-tokens)
# EXPO_TOKEN=
# Required for Android push notifications (from `eas init` or Expo project settings):
# EXPO_PUBLIC_EAS_PROJECT_ID=your-expo-project-uuid
