{
  "id": "/messenger",
  "name": "Abcotronics Messenger",
  "short_name": "Messenger",
  "description": "Team chat and direct messages — Abcotronics ERP",
  "start_url": "/messenger.html?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "browser"],
  "orientation": "any",
  "theme_color": "#2563eb",
  "background_color": "#f8fafc",
  "lang": "en-ZA",
  "dir": "ltr",
  "categories": ["business", "social", "productivity"],
  "icons": [
    {
      "src": "/favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/favicon.ico",
      "sizes": "48x48",
      "type": "image/x-icon",
      "purpose": "any"
    }
  ]
}
