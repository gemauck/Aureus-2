{
  "name": "abcotronics-erp-modular",
  "version": "0.1.20",
  "description": "Abcotronics - Fuel Management Services",
  "type": "module",
  "main": "server.js",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
